<Window x:Class="CodexIsland.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:CodexIsland.App.Controls"
        mc:Ignorable="d"
        Title="Codex Island"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="RoundIconButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Foreground" Value="#9AA0A6"/>
            <Setter Property="Background" Value="#24262B"/>
            <Setter Property="BorderBrush" Value="#30343A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30343A"/>
                                <Setter Property="Foreground" Value="#E8E8EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IslandActionButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Foreground" Value="#EAE5DC"/>
            <Setter Property="Background" Value="#252320"/>
            <Setter Property="BorderBrush" Value="#3A3631"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F2C28"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CC785C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatCardIconButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Foreground" Value="#5A5A5A"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#202020"/>
                                <Setter Property="Foreground" Value="#9AA0A6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IslandToolTip" TargetType="ToolTip">
            <Setter Property="Background" Value="#191B1F"/>
            <Setter Property="Foreground" Value="#E6E8EB"/>
            <Setter Property="BorderBrush" Value="#323841"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IslandScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#4C545F"
                                CornerRadius="4"
                                Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IslandVerticalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="#111214"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Margin="2,0,0,0">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource IslandScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="10,8,10,12" RenderTransformOrigin="0.5,0.08">
        <Border.RenderTransform>
            <ScaleTransform x:Name="IslandScale" ScaleX="1" ScaleY="1"/>
        </Border.RenderTransform>
        <Border Background="#0D0D0D"
                BorderBrush="#282828"
                BorderThickness="1"
                CornerRadius="18">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
            </Border.Effect>

            <StackPanel>
                <Grid Height="50" Margin="10,0,10,0" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <controls:SignalLightBar Grid.Column="0"
                                             Signal="{Binding CurrentSignal}"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="{Binding Title}"
                               Foreground="#E0E0E0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="18,0,8,0"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="{Binding ChevronGlyph}"
                                Command="{Binding ToggleExpandedCommand}"
                                Style="{StaticResource RoundIconButton}"
                                ToolTip="Expand or collapse"/>
                        <Button x:Name="PinButton"
                                Content="&#xE718;"
                                Click="PinButton_Click"
                                Style="{StaticResource RoundIconButton}"
                                Margin="4,0,0,0"
                                ToolTip="Always on top"/>
                        <Button Content="&#xE8BB;"
                                Click="CloseButton_Click"
                                Style="{StaticResource RoundIconButton}"
                                Margin="4,0,0,0"
                                ToolTip="Hide"/>
                    </StackPanel>
                </Grid>

                <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                    <Rectangle Height="1" Fill="#1C1C1C"/>

                    <Border Background="#111111"
                            CornerRadius="10"
                            Margin="8,6,8,2"
                            Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding CpuText}"
                                       Foreground="#9AA0A6"
                                       FontSize="11"
                                       FontFamily="Consolas, Cascadia Code, Segoe UI"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RamText}"
                                       Foreground="#9AA0A6"
                                       FontSize="11"
                                       FontFamily="Consolas, Cascadia Code, Segoe UI"
                                       FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding GpuText}"
                                       Foreground="#9AA0A6"
                                       FontSize="11"
                                       FontFamily="Consolas, Cascadia Code, Segoe UI"
                                       FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="8,0,0,0">
                                <TextBlock Text="&#xE701;"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding NetTrafficText}"
                                           Foreground="#9AA0A6"
                                           FontSize="11"
                                           FontFamily="Consolas, Cascadia Code, Segoe UI"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Model selection bar -->
                    <Border Background="#111111" CornerRadius="10" Margin="8,0,8,2" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="ModelMenuToggle" Grid.Column="0" Cursor="Hand"
                                          FocusVisualStyle="{x:Null}"
                                          IsChecked="{Binding ModelMenuOpen, Mode=TwoWay}"
                                          ToolTip="Switch model">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="#252320" BorderBrush="#3A3631"
                                                BorderThickness="1" CornerRadius="8" Padding="9,5">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#CC785C" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ActiveModelName}"
                                                           Foreground="#CC785C" FontSize="11" FontWeight="SemiBold"
                                                           Margin="6,1,0,0" VerticalAlignment="Center"/>
                                                <Path Margin="4,2,0,0" VerticalAlignment="Center" Fill="#CC785C" Data="M0,0 L4,4 L8,0 Z"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CC785C"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#2F2C28"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CC785C"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup PlacementTarget="{Binding ElementName=ModelMenuToggle}" Placement="Bottom"
                                   VerticalOffset="4" IsOpen="{Binding ModelMenuOpen, Mode=TwoWay}"
                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="#252320" BorderBrush="#3A3631" BorderThickness="1"
                                        CornerRadius="8" Padding="4" MinWidth="180">
                                    <ItemsControl ItemsSource="{Binding ModelChoices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Cursor="Hand" FocusVisualStyle="{x:Null}"
                                                        Command="{Binding DataContext.SwitchToModelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="IBd" Background="Transparent" CornerRadius="6" Padding="10,6" Margin="1">
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}" Foreground="#FAF9F5" FontSize="12" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding Description}" Foreground="#8B8780" FontSize="10"
                                                                               Margin="0,1,0,0"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="IBd" Property="Background" Value="#2F2C28"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Popup>

                            <TextBlock Grid.Column="1" Text="&#xE946;"
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="#5A5A5A" FontSize="12"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Border Margin="8,0,8,8"
                            Background="#111111"
                            CornerRadius="10"
                            Padding="12,10,12,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="84"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal">
                                <Ellipse Width="12" Height="12" Fill="{Binding QuotaBrush}" Margin="0,3,9,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#FF6B7B" Opacity="0.78"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <StackPanel>
                                    <TextBlock Text="Codex quota"
                                               Foreground="#F2F2F7"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding QuotaCaption}"
                                               Foreground="{Binding QuotaBrush}"
                                               FontSize="9"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid Grid.Row="1" Grid.RowSpan="2"
                                  Grid.Column="0"
                                  Width="88"
                                  Height="88"
                                  VerticalAlignment="Center">
                                <controls:QuotaSphereControl RemainingPercent="{Binding RemainingPercent}"
                                                             Health="{Binding QuotaHealth}"/>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding RemainingText}"
                                               Foreground="#FFFFFF"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="left"
                                               Foreground="#DDE5F1"
                                               FontSize="9"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="1"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="14,0,0,0"
                                        Width="138">
                                <Border Background="#1A1C20"
                                        BorderBrush="{Binding QuotaBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,5">
                                    <StackPanel>
                                        <TextBlock Text="5h window" Foreground="#BAC3D1" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding QuotaWindowText}" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold" Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding ResetText}" Foreground="#AAB5C3" FontSize="9" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="1"
                                        VerticalAlignment="Top"
                                        Margin="14,2,0,0"
                                        Width="138">
                                <Border Background="#1A1C20"
                                        BorderBrush="{Binding QuotaBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,5">
                                    <StackPanel>
                                        <TextBlock Text="7d window" Foreground="#BAC3D1" FontSize="10" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding WeeklyQuotaText}" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold" Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding WeeklyResetText}" Foreground="#AAB5C3" FontSize="9" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                                        <Border Height="6" CornerRadius="3" Background="#111317">
                                            <Border Height="6"
                                                    HorizontalAlignment="Left"
                                                    Background="{Binding QuotaBrush}"
                                                    CornerRadius="3"
                                                    Width="{Binding WeeklyProgressBarWidth}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Margin="8,0,8,8"
                                  MaxHeight="272"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource IslandVerticalScrollBar}"/>
                            <Style TargetType="ToolTip" BasedOn="{StaticResource IslandToolTip}"/>
                        </ScrollViewer.Resources>
                        <ItemsControl ItemsSource="{Binding ProjectItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#101112"
                                            BorderBrush="#151719"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="12,9"
                                            Margin="0,0,0,8"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="ProjectCard_MouseLeftButtonUp"
                                            ToolTip="{Binding ToolTipText}"
                                            ToolTipService.ShowDuration="60000"
                                            ToolTipService.InitialShowDelay="200">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <controls:StatusDot Signal="{Binding Signal}" VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#F1F3F5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="176"/>
                                                <TextBlock Text="{Binding ActionText}"
                                                           Foreground="#555A61"
                                                           FontSize="9"
                                                           Margin="8,1,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#xE8A7;" Style="{StaticResource FlatCardIconButton}" ToolTip="Open project" Click="ProjectOpenButton_Click"/>
                                                <Button Content="&#xE945;" Style="{StaticResource FlatCardIconButton}" ToolTip="auto mode"/>
                                                <Button Content="&#xE70F;" Style="{StaticResource FlatCardIconButton}" ToolTip="plan mode"/>
                                                <Button Content="&#xE718;" Style="{StaticResource FlatCardIconButton}" ToolTip="pin"/>
                                                <Button Content="&#xE8BB;" Style="{StaticResource FlatCardIconButton}" ToolTip="dismiss"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</Window>
